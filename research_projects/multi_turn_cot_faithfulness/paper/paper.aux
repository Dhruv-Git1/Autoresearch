\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {Anchoring is not reducible to answer inertia (three-panel, combined $N=67$).} \emph  {Left:} Repetition rate by CoT mode: 75.8\% of anchored vs.\ 45.6\% of exploring turns repeat the prior answer ($1.66\times $ ratio, below the $2\times $ threshold). \emph  {Centre:} Three-way turn decomposition --- exploring (76.7\%), repetition-anchored (17.2\%), and novel-anchored (5.6\%); the novel-anchored slice cannot be explained by answer copying. \emph  {Right:} At anchored turns, the 100\%-CoT answer equals the 0\%-CoT answer $\approx $89\% of the time; at exploring turns this rate is $\approx $17\%, confirming CoT truncation level is causally active at exploring turns but not at anchored turns.}}{17}{figure.10}\protected@file@percent }
\newlabel{fig:inertiafull}{{10}{17}{\textbf {Anchoring is not reducible to answer inertia (three-panel, combined $N=67$).} \emph {Left:} Repetition rate by CoT mode: 75.8\% of anchored vs.\ 45.6\% of exploring turns repeat the prior answer ($1.66\times $ ratio, below the $2\times $ threshold). \emph {Centre:} Three-way turn decomposition --- exploring (76.7\%), repetition-anchored (17.2\%), and novel-anchored (5.6\%); the novel-anchored slice cannot be explained by answer copying. \emph {Right:} At anchored turns, the 100\%-CoT answer equals the 0\%-CoT answer $\approx $89\% of the time; at exploring turns this rate is $\approx $17\%, confirming CoT truncation level is causally active at exploring turns but not at anchored turns}{figure.10}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Cumulative anchoring statistics across phases. H3: global anchored fraction (both turn types ``substantially present''). Variance test: chi-square test of between-conversation variance vs.\ Bernoulli null (Section~\ref {sec:method}). $\text  {$\mathsurround \z@ \mathchar "458$}$~H3 confirmed at all scales. H1 (run-length persistence) was tested with a corrected parametric bootstrap on all $N=67$ conversations (148~anchored runs): bootstrap $p=0.521$, non-significant; see Section~\ref {subsec:h1}. All intermediate H1 p-values computed with scipy's \texttt  {kstest} are invalid on discrete data and are omitted here. $^\dagger $~Raw JSONL observation count (before the $\geq $3-parseable-regeneration filter); the Anchored (H3) column uses the 1,167~assessable-turn denominator throughout (see Section~\ref {sec:method} footnote~1).}}{17}{table.3}\protected@file@percent }
\newlabel{tab:cascade}{{3}{17}{Cumulative anchoring statistics across phases. H3: global anchored fraction (both turn types ``substantially present''). Variance test: chi-square test of between-conversation variance vs.\ Bernoulli null (Section~\ref {sec:method}). $\checkmark $~H3 confirmed at all scales. H1 (run-length persistence) was tested with a corrected parametric bootstrap on all $N=67$ conversations (148~anchored runs): bootstrap $p=0.521$, non-significant; see Section~\ref {subsec:h1}. All intermediate H1 p-values computed with scipy's \texttt {kstest} are invalid on discrete data and are omitted here. $^\dagger $~Raw JSONL observation count (before the $\geq $3-parseable-regeneration filter); the Anchored (H3) column uses the 1,167~assessable-turn denominator throughout (see Section~\ref {sec:method} footnote~1)}{table.3}{}}
