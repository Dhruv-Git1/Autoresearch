\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Conversation-level anchoring is structured, not noise (ICC$=0.152$).} \emph  {Top:} Caterpillar plot --- each Phase~A conversation's empirical anchored fraction with 95\% Wilson CI, compared against the Bernoulli null band (grey). Many conversations lie outside the null band (expected 5\%), confirming the between-conversation spread vastly exceeds chance. Colour encodes conversation length bin. \emph  {Bottom-left:} Boxplots of anchored fraction by length bin (Phase~A individual data; $\diamond $ = combined $N=67$ mean). \emph  {Bottom-right:} Within-bin variance tests --- H3 holds inside medium ($p=0.0035$) and long ($p{<}0.001$) strata, ruling out length heterogeneity as the sole driver.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:perconvh3}{{3}{9}{\textbf {Conversation-level anchoring is structured, not noise (ICC$=0.152$).} \emph {Top:} Caterpillar plot --- each Phase~A conversation's empirical anchored fraction with 95\% Wilson CI, compared against the Bernoulli null band (grey). Many conversations lie outside the null band (expected 5\%), confirming the between-conversation spread vastly exceeds chance. Colour encodes conversation length bin. \emph {Bottom-left:} Boxplots of anchored fraction by length bin (Phase~A individual data; $\diamond $ = combined $N=67$ mean). \emph {Bottom-right:} Within-bin variance tests --- H3 holds inside medium ($p=0.0035$) and long ($p{<}0.001$) strata, ruling out length heterogeneity as the sole driver}{figure.3}{}}
