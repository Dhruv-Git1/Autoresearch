\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {H2 confound analysis ($N=53$ labelled conversations).} \emph  {Left:} Length-bias in sample composition. Green circles = original extractor labels (all correct, mean 9.6~turns); red crosses = recovered labels (all wrong, mean 19.8~turns). The two groups are separated by length, not anchoring rate. \emph  {Right:} Pairwise Pearson correlations with 95\% CIs. Significant correlations (red) are between length and anchoring, and between length and correctness. The anchoring--correctness correlation (blue, $r = -0.097$) is non-significant and its CI straddles zero.}}{10}{figure.4}\protected@file@percent }
\newlabel{fig:h2confound}{{4}{10}{\textbf {H2 confound analysis ($N=53$ labelled conversations).} \emph {Left:} Length-bias in sample composition. Green circles = original extractor labels (all correct, mean 9.6~turns); red crosses = recovered labels (all wrong, mean 19.8~turns). The two groups are separated by length, not anchoring rate. \emph {Right:} Pairwise Pearson correlations with 95\% CIs. Significant correlations (red) are between length and anchoring, and between length and correctness. The anchoring--correctness correlation (blue, $r = -0.097$) is non-significant and its CI straddles zero}{figure.4}{}}
