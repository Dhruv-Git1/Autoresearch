\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Answer-token margin distributions: anchored vs.\ exploring turns are indistinguishable.} \emph  {Left:} margin at 0\%~CoT --- the model picks its argmax with very high confidence in both modes (median $\approx 12$~nats). \emph  {Centre:} margin at 100\%~CoT --- same. \emph  {Right:} $\Delta $~margin --- adding the full CoT raises confidence by about 2~nats in both modes; the predicted ``anchored~$\to $~near-zero $\Delta $'' signature does not appear. The token-level confidence metric is not diagnostic of mode; anchoring is an answer-stability phenomenon, not a token-confidence phenomenon.}}{13}{figure.6}\protected@file@percent }
\newlabel{fig:logprobs}{{6}{13}{\textbf {Answer-token margin distributions: anchored vs.\ exploring turns are indistinguishable.} \emph {Left:} margin at 0\%~CoT --- the model picks its argmax with very high confidence in both modes (median $\approx 12$~nats). \emph {Centre:} margin at 100\%~CoT --- same. \emph {Right:} $\Delta $~margin --- adding the full CoT raises confidence by about 2~nats in both modes; the predicted ``anchored~$\to $~near-zero $\Delta $'' signature does not appear. The token-level confidence metric is not diagnostic of mode; anchoring is an answer-stability phenomenon, not a token-confidence phenomenon}{figure.6}{}}
