\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces \textbf  {Mode-switching evidence accumulates across phases.} \emph  {Left:} Trajectory of the (invalid) scipy \texttt  {kstest} p-value for H1 as $N$ grows --- shown here only to illustrate how power appeared to build before the test was corrected. The valid parametric bootstrap p-value stayed near 0.52--0.56 at all scales; H1 remains inconclusive throughout (Section~\ref {subsec:h1}). The jump at $N=14{\to }24$ reflects both more runs \emph  {and} Phase~4's longer conversations (max\_shards~$=10$), confounding the power increase. \emph  {Right:} Anchored fraction remains 8--14\% across all Phase~A scales, confirming both turn types are persistently present.}}{26}{figure.15}\protected@file@percent }
\newlabel{fig:cascade}{{15}{26}{\textbf {Mode-switching evidence accumulates across phases.} \emph {Left:} Trajectory of the (invalid) scipy \texttt {kstest} p-value for H1 as $N$ grows --- shown here only to illustrate how power appeared to build before the test was corrected. The valid parametric bootstrap p-value stayed near 0.52--0.56 at all scales; H1 remains inconclusive throughout (Section~\ref {subsec:h1}). The jump at $N=14{\to }24$ reflects both more runs \emph {and} Phase~4's longer conversations (max\_shards~$=10$), confounding the power increase. \emph {Right:} Anchored fraction remains 8--14\% across all Phase~A scales, confirming both turn types are persistently present}{figure.15}{}}
\@writefile{toc}{\contentsline {paragraph}{Additional figures.}{26}{figure.19}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces \textbf  {Per-conversation summary (Phase~A, $N=24$).} \emph  {Left:} Anchored fraction vs.\ conversation length; marker size encodes the longest anchored run. Longer conversations tend to have higher anchored fractions (see also Section~\ref {subsec:length} for the length-stratified analysis). \emph  {Right:} Phase~A H3 distribution (13\% anchored / 87\% exploring; combined $N=67$ gives 23.3\% anchored) with the Phase~A variance test p-value.}}{27}{figure.16}\protected@file@percent }
\newlabel{fig:scatter}{{16}{27}{\textbf {Per-conversation summary (Phase~A, $N=24$).} \emph {Left:} Anchored fraction vs.\ conversation length; marker size encodes the longest anchored run. Longer conversations tend to have higher anchored fractions (see also Section~\ref {subsec:length} for the length-stratified analysis). \emph {Right:} Phase~A H3 distribution (13\% anchored / 87\% exploring; combined $N=67$ gives 23.3\% anchored) with the Phase~A variance test p-value}{figure.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces \textbf  {Truncation sensitivity: anchored turns are invariant across all 5 CoT levels (Phase~A).} \emph  {Left:} Agreement heatmap for representative anchored (red rows) and exploring (green rows) turns --- each cell shows whether that truncation level produced the same answer as the 100\%~CoT level. Anchored turns are all-green; exploring turns have at least one red cell. \emph  {Right:} Histogram of unique answer count across 5 levels: anchored turns always produce exactly~1 unique answer; exploring turns produce~2 or more. The bimodal distribution validates the binary anchored/exploring classification.}}{27}{figure.17}\protected@file@percent }
\newlabel{fig:truncsens}{{17}{27}{\textbf {Truncation sensitivity: anchored turns are invariant across all 5 CoT levels (Phase~A).} \emph {Left:} Agreement heatmap for representative anchored (red rows) and exploring (green rows) turns --- each cell shows whether that truncation level produced the same answer as the 100\%~CoT level. Anchored turns are all-green; exploring turns have at least one red cell. \emph {Right:} Histogram of unique answer count across 5 levels: anchored turns always produce exactly~1 unique answer; exploring turns produce~2 or more. The bimodal distribution validates the binary anchored/exploring classification}{figure.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces \textbf  {Inertia decomposition (combined $N=67$).} \emph  {Left:} Three-way turn decomposition: exploring (76.7\%), repetition-anchored (answer matches prior turn, 17.2\%), and novel-anchored (answer does not match prior turn, 6.1\%). The 6.1\% of novel-anchored turns cannot be explained by answer inertia --- the model generates a fresh number that all five CoT levels agree on. \emph  {Right:} At anchored turns, the 100\%~CoT answer equals the 0\%~CoT answer in every case; at exploring turns this rate is much lower, confirming that CoT truncation level is causally active at exploring turns but not at anchored turns.}}{28}{figure.18}\protected@file@percent }
\newlabel{fig:inertia}{{18}{28}{\textbf {Inertia decomposition (combined $N=67$).} \emph {Left:} Three-way turn decomposition: exploring (76.7\%), repetition-anchored (answer matches prior turn, 17.2\%), and novel-anchored (answer does not match prior turn, 6.1\%). The 6.1\% of novel-anchored turns cannot be explained by answer inertia --- the model generates a fresh number that all five CoT levels agree on. \emph {Right:} At anchored turns, the 100\%~CoT answer equals the 0\%~CoT answer in every case; at exploring turns this rate is much lower, confirming that CoT truncation level is causally active at exploring turns but not at anchored turns}{figure.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces \textbf  {H3 caterpillar plot: between-conversation spread vastly exceeds the Bernoulli null (Phase~A, $N=24$; 4~conversations with $<$4~assessable turns omitted for Wilson-CI stability).} Each dot is one conversation's empirical anchored fraction with a 95\% Wilson confidence interval. The grey band shows the expected variation under a Bernoulli($p=0.233$) null for each conversation's size. Conversations outside the null band (many more than the expected~5\%) demonstrate that anchoring is a conversation-level property, not per-turn noise. Color encodes conversation length bin. Inset: ICC~$=0.152$ (robust test, random-effects ANOVA).}}{28}{figure.19}\protected@file@percent }
\newlabel{fig:caterpillar}{{19}{28}{\textbf {H3 caterpillar plot: between-conversation spread vastly exceeds the Bernoulli null (Phase~A, $N=24$; 4~conversations with $<$4~assessable turns omitted for Wilson-CI stability).} Each dot is one conversation's empirical anchored fraction with a 95\% Wilson confidence interval. The grey band shows the expected variation under a Bernoulli($p=0.233$) null for each conversation's size. Conversations outside the null band (many more than the expected~5\%) demonstrate that anchoring is a conversation-level property, not per-turn noise. Color encodes conversation length bin. Inset: ICC~$=0.152$ (robust test, random-effects ANOVA)}{figure.19}{}}
