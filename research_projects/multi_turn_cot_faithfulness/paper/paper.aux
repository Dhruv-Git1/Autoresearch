\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Answer-token margin distributions: anchored vs.\ exploring turns are indistinguishable.} \emph  {Left:} margin at 0\%~CoT --- the model picks its argmax with very high confidence in both modes (median $\approx 12$~nats). \emph  {Centre:} margin at 100\%~CoT --- same. \emph  {Right:} $\Delta $~margin --- adding the full CoT raises confidence by about 2~nats in both modes; the predicted ``anchored~$\to $~near-zero $\Delta $'' signature does not appear. The token-level confidence metric is not diagnostic of mode; anchoring is an answer-stability phenomenon, not a token-confidence phenomenon.}}{11}{figure.5}\protected@file@percent }
\newlabel{fig:logprobs}{{5}{11}{\textbf {Answer-token margin distributions: anchored vs.\ exploring turns are indistinguishable.} \emph {Left:} margin at 0\%~CoT --- the model picks its argmax with very high confidence in both modes (median $\approx 12$~nats). \emph {Centre:} margin at 100\%~CoT --- same. \emph {Right:} $\Delta $~margin --- adding the full CoT raises confidence by about 2~nats in both modes; the predicted ``anchored~$\to $~near-zero $\Delta $'' signature does not appear. The token-level confidence metric is not diagnostic of mode; anchoring is an answer-stability phenomenon, not a token-confidence phenomenon}{figure.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Answer-token confidence on anchored vs.\ exploring turns. Margin~$=$~chosen-token logprob~$-$~top-alternative logprob. All three comparisons are non-significant and effect sizes are below ``small'' ($d < 0.2$): the chosen-token confidence metric is not diagnostic of mode.}}{11}{table.2}\protected@file@percent }
\newlabel{tab:logprob}{{2}{11}{Answer-token confidence on anchored vs.\ exploring turns. Margin~$=$~chosen-token logprob~$-$~top-alternative logprob. All three comparisons are non-significant and effect sizes are below ``small'' ($d < 0.2$): the chosen-token confidence metric is not diagnostic of mode}{table.2}{}}
