\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {H2 is length-confounded, but H2b (anchoring suppresses answer updates) survives length control.} \emph  {Left:} Sample composition scatter --- originals (green, $N=16$, all correct, mean 9.6~turns) and recovered (red, $N=37$, all wrong, mean 19.8~turns) are separated by length, not anchoring rate; the correctness signal is a length proxy. \emph  {Centre:} Pairwise Pearson correlations ($N=53$): length predicts both anchoring ($r=0.42$, $p{<}0.01$) and correctness ($r=-0.37$, $p{<}0.01$); the anchoring--correctness correlation ($r=-0.097$) is non-significant. \emph  {Right:} H2b scatter --- conversations that anchor more frequently update their 0\%-CoT answer less across turns; Spearman $\rho =-0.426$, $p=0.001$, $N=59$; partial $\rho =-0.337$, $p=0.009$ after controlling for length.}}{12}{figure.6}\protected@file@percent }
\newlabel{fig:h2full}{{6}{12}{\textbf {H2 is length-confounded, but H2b (anchoring suppresses answer updates) survives length control.} \emph {Left:} Sample composition scatter --- originals (green, $N=16$, all correct, mean 9.6~turns) and recovered (red, $N=37$, all wrong, mean 19.8~turns) are separated by length, not anchoring rate; the correctness signal is a length proxy. \emph {Centre:} Pairwise Pearson correlations ($N=53$): length predicts both anchoring ($r=0.42$, $p{<}0.01$) and correctness ($r=-0.37$, $p{<}0.01$); the anchoring--correctness correlation ($r=-0.097$) is non-significant. \emph {Right:} H2b scatter --- conversations that anchor more frequently update their 0\%-CoT answer less across turns; Spearman $\rho =-0.426$, $p=0.001$, $N=59$; partial $\rho =-0.337$, $p=0.009$ after controlling for length}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Monitor-evasion gap: monitor confidence grows as conversations lengthen.} \emph  {Left:} Distribution of per-turn monitor scores by length bin. Long conversations (red) accumulate more mass at 1.0 than short conversations (blue). \emph  {Right:} Mean per-conversation monitor score rises with conversation length (0.482 short $\to $ 0.510 medium $\to $ 0.650 long) as a mechanical consequence of the anchoring gradient. Error bars are 95\% CI. The perfect-trust rate (score~$=1.0$) grows $4\times $ from short to long conversations (7.4\% vs.\ 28.3\%), the operational monitor blind-spot measure.}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:monitor}{{7}{12}{\textbf {Monitor-evasion gap: monitor confidence grows as conversations lengthen.} \emph {Left:} Distribution of per-turn monitor scores by length bin. Long conversations (red) accumulate more mass at 1.0 than short conversations (blue). \emph {Right:} Mean per-conversation monitor score rises with conversation length (0.482 short $\to $ 0.510 medium $\to $ 0.650 long) as a mechanical consequence of the anchoring gradient. Error bars are 95\% CI. The perfect-trust rate (score~$=1.0$) grows $4\times $ from short to long conversations (7.4\% vs.\ 28.3\%), the operational monitor blind-spot measure}{figure.7}{}}
