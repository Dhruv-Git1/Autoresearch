\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Turn-level CoT faithfulness classification.} \emph  {Top:} Turn-by-turn classification for sample 965 (first 40 of 44 total turns shown; final 4 are all exploring): green = exploring (CoT drives the answer), red = anchored (CoT is post-hoc). The red burst coincides with premature commitment to the wrong answer ``300'' (gold = 660). \emph  {Bottom left:} On exploring turns, different truncation levels produce different answers---the CoT is causally active. \emph  {Bottom right:} On anchored turns, all five levels agree on the same answer regardless of how much reasoning is visible---the current-turn CoT is insufficient to change the answer.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:concept}{{1}{3}{\textbf {Turn-level CoT faithfulness classification.} \emph {Top:} Turn-by-turn classification for sample 965 (first 40 of 44 total turns shown; final 4 are all exploring): green = exploring (CoT drives the answer), red = anchored (CoT is post-hoc). The red burst coincides with premature commitment to the wrong answer ``300'' (gold = 660). \emph {Bottom left:} On exploring turns, different truncation levels produce different answers---the CoT is causally active. \emph {Bottom right:} On anchored turns, all five levels agree on the same answer regardless of how much reasoning is visible---the current-turn CoT is insufficient to change the answer}{figure.1}{}}
