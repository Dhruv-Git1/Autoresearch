\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \textbf  {Per-conversation summary (Phase~A, $N=24$).} \emph  {Left:} Anchored fraction vs.\ conversation length; marker size encodes the longest anchored run. Longer conversations tend to have higher anchored fractions (see also Section~\ref {subsec:length} for the length-stratified analysis). \emph  {Right:} Phase~A H3 distribution (13\% anchored / 87\% exploring; combined $N=67$ gives 23.3\% anchored) with the Phase~A variance test p-value.}}{21}{figure.13}\protected@file@percent }
\newlabel{fig:scatter}{{13}{21}{\textbf {Per-conversation summary (Phase~A, $N=24$).} \emph {Left:} Anchored fraction vs.\ conversation length; marker size encodes the longest anchored run. Longer conversations tend to have higher anchored fractions (see also Section~\ref {subsec:length} for the length-stratified analysis). \emph {Right:} Phase~A H3 distribution (13\% anchored / 87\% exploring; combined $N=67$ gives 23.3\% anchored) with the Phase~A variance test p-value}{figure.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces \textbf  {Truncation sensitivity: anchored turns are invariant across all 5 CoT levels (Phase~A).} \emph  {Left:} Agreement heatmap for representative anchored (red rows) and exploring (green rows) turns --- each cell shows whether that truncation level produced the same answer as the 100\%~CoT level. Anchored turns are all-green; exploring turns have at least one red cell. \emph  {Right:} Histogram of unique answer count across 5 levels: anchored turns always produce exactly~1 unique answer; exploring turns produce~2 or more. The bimodal distribution validates the binary anchored/exploring classification.}}{21}{figure.14}\protected@file@percent }
\newlabel{fig:truncsens}{{14}{21}{\textbf {Truncation sensitivity: anchored turns are invariant across all 5 CoT levels (Phase~A).} \emph {Left:} Agreement heatmap for representative anchored (red rows) and exploring (green rows) turns --- each cell shows whether that truncation level produced the same answer as the 100\%~CoT level. Anchored turns are all-green; exploring turns have at least one red cell. \emph {Right:} Histogram of unique answer count across 5 levels: anchored turns always produce exactly~1 unique answer; exploring turns produce~2 or more. The bimodal distribution validates the binary anchored/exploring classification}{figure.14}{}}
\newlabel{checklist_ai_involvement}{{A}{21}{Conference For AI Scientists 2026 --- AI Involvement Checklist}{section*.57}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces \textbf  {Inertia decomposition (combined $N=67$).} \emph  {Left:} Three-way turn decomposition: exploring (76.7\%), repetition-anchored (answer matches prior turn, 17.7\%), and novel-anchored (answer does not match prior turn, 5.6\%). The 5.6\% of novel-anchored turns cannot be explained by answer inertia --- the model generates a fresh number that all five CoT levels agree on. \emph  {Right:} At anchored turns, the 100\%~CoT answer equals the 0\%~CoT answer in every case; at exploring turns this rate is much lower, confirming that CoT truncation level is causally active at exploring turns but not at anchored turns.}}{22}{figure.15}\protected@file@percent }
\newlabel{fig:inertia}{{15}{22}{\textbf {Inertia decomposition (combined $N=67$).} \emph {Left:} Three-way turn decomposition: exploring (76.7\%), repetition-anchored (answer matches prior turn, 17.7\%), and novel-anchored (answer does not match prior turn, 5.6\%). The 5.6\% of novel-anchored turns cannot be explained by answer inertia --- the model generates a fresh number that all five CoT levels agree on. \emph {Right:} At anchored turns, the 100\%~CoT answer equals the 0\%~CoT answer in every case; at exploring turns this rate is much lower, confirming that CoT truncation level is causally active at exploring turns but not at anchored turns}{figure.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces \textbf  {H3 caterpillar plot: between-conversation spread vastly exceeds the Bernoulli null (Phase~A, $N=20$).} Each dot is one conversation's empirical anchored fraction with a 95\% Wilson confidence interval. The grey band shows the expected variation under a Bernoulli($p=0.233$) null for each conversation's size. Conversations outside the null band (many more than the expected~5\%) demonstrate that anchoring is a conversation-level property, not per-turn noise. Color encodes conversation length bin. Inset: ICC~$=0.152$ (robust test, random-effects ANOVA).}}{23}{figure.16}\protected@file@percent }
\newlabel{fig:caterpillar}{{16}{23}{\textbf {H3 caterpillar plot: between-conversation spread vastly exceeds the Bernoulli null (Phase~A, $N=20$).} Each dot is one conversation's empirical anchored fraction with a 95\% Wilson confidence interval. The grey band shows the expected variation under a Bernoulli($p=0.233$) null for each conversation's size. Conversations outside the null band (many more than the expected~5\%) demonstrate that anchoring is a conversation-level property, not per-turn noise. Color encodes conversation length bin. Inset: ICC~$=0.152$ (robust test, random-effects ANOVA)}{figure.16}{}}
