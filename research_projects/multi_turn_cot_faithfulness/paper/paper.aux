\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {H2b: Anchoring rate predicts answer update failure ($N=59$ conversations).} Each point is one conversation. Conversations that anchor more frequently are less likely to update their context-only (0\%-CoT) answer across turns as new shards arrive. Spearman $\rho = -0.426$, $p = 0.001$. The correlation is distinct from anchoring by construction: update rate measures temporal change in the 0\%-level answer; anchoring rate measures cross-level invariance at a single turn.}}{15}{figure.8}\protected@file@percent }
\newlabel{fig:h2b}{{8}{15}{\textbf {H2b: Anchoring rate predicts answer update failure ($N=59$ conversations).} Each point is one conversation. Conversations that anchor more frequently are less likely to update their context-only (0\%-CoT) answer across turns as new shards arrive. Spearman $\rho = -0.426$, $p = 0.001$. The correlation is distinct from anchoring by construction: update rate measures temporal change in the 0\%-level answer; anchoring rate measures cross-level invariance at a single turn}{figure.8}{}}
